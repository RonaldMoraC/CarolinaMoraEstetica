{
    "name": "carolina-mora\/estetica-ecosystem",
    "description": "Ecosistema Digital Omnicanal — Estética Carolina Mora",
    "type": "project",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit\/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src\/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests\/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
